# Canonical site URL — RSS, sitemap, absolute links (no trailing slash).
# `next dev` loads `.env.development` in this repo (canonical feed URLs). Override with `.env.local` if needed.
# Production: wrangler.jsonc `vars` / dashboard (see README).
# NEXT_PUBLIC_SITE_URL=https://docs.altriayu.uk
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-your-turnstile-site-key
# NEXT_PUBLIC_AVATAR_BASE_URL=https://your-cdn.example.com
