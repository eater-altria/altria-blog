# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# OpenNext → Cloudflare Workers build output
/.open-next/

# production
/build

# Cloudflare Wrangler (local D1 state, Miniflare caches, dev registry logs)
.wrangler/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env & secrets (Wrangler uses .dev.vars alongside .env)
.env*
!.env.example
.dev.vars

# vercel
.vercel

# typescript
*.tsbuildinfo
